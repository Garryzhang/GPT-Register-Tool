<Window x:Class="SmsWorkbench.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GPT Register Tool" Icon="Assets/app-icon.ico" Height="780" Width="1320" MinHeight="680" MinWidth="1180"
        WindowStartupLocation="CenterScreen" Background="{StaticResource AppBg}"
        FontFamily="Microsoft YaHei UI" FontSize="13">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="{StaticResource SidebarBg}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="14,16,14,10">
          <DockPanel>
            <Button x:Name="SidebarToggleButton" Content="‹" DockPanel.Dock="Right" Width="34" Click="ToggleSidebar_Click"/>
            <StackPanel x:Name="SidebarHeaderText">
              <TextBlock Text="GPT Register" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextMain}"/>
              <TextBlock Text="邮箱注册与支付链接固化" Margin="0,4,0,0" Foreground="{StaticResource TextSub}"/>
            </StackPanel>
          </DockPanel>
        </StackPanel>

        <StackPanel x:Name="SidebarBottomActions" DockPanel.Dock="Bottom" Margin="10,0,10,14">
          <Button Content="主题切换" Click="ToggleTheme_Click"/>
          <Button Content="刷新" Click="Refresh_Click"/>
          <Button Content="配置" Click="Settings_Click"/>
          <Button Content="取消批次" Style="{StaticResource DangerButton}" Click="CancelBatch_Click"/>
        </StackPanel>

        <ScrollViewer x:Name="SidebarNavScroll" VerticalScrollBarVisibility="Auto">
          <StackPanel Margin="10,0,10,12">
            <TextBlock Text="邮箱管理" FontWeight="SemiBold" Foreground="{StaticResource TextSub}" Margin="6,8,0,6"/>
            <Button Content="导入Chatai邮箱" Margin="18,0,4,6" Click="ImportChataiMailbox_Click"/>
            <Button Content="查看收件箱" Margin="18,0,4,6" Click="ViewInbox_Click"/>

            <TextBlock Text="注册流程" FontWeight="SemiBold" Foreground="{StaticResource TextSub}" Margin="6,16,0,6"/>
            <Button Content="购买邮箱并注册" Margin="18,0,4,6" Style="{StaticResource PrimaryButton}" Click="BuyAndRegister_Click"/>
            <Button Content="一键注册+支付链接" Margin="18,0,4,6" Click="OneClickRegister_Click"/>

            <TextBlock Text="数据维护" FontWeight="SemiBold" Foreground="{StaticResource TextSub}" Margin="6,16,0,6"/>
            <Button Content="打开支付链接" Margin="18,0,4,6" Click="OpenPayPalLink_Click"/>
            <Button Content="标记支付完成" Margin="18,0,4,6" Click="MarkPayPalComplete_Click"/>
            <Button Content="一键导入CPA" Margin="18,0,4,6" Click="ImportPaidCpa_Click"/>
            <Button Content="重新生成链接" Margin="18,0,4,6" Click="RegeneratePayPalLink_Click"/>
            <Button Content="删除选中" Margin="18,0,4,6" Click="DeleteSelected_Click"/>
          </StackPanel>
        </ScrollViewer>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="10">
      <Grid.RowDefinitions>
        <RowDefinition Height="92"/>
        <RowDefinition Height="46"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="6"/>
        <RowDefinition Height="300" MinHeight="180"/>
        <RowDefinition Height="24"/>
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Border Grid.Column="0" Margin="0,0,8,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
          <StackPanel Margin="14,12">
            <TextBlock Text="总记录" Foreground="{StaticResource TextSub}"/>
            <TextBlock Text="{Binding TotalCountText}" FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="1" Margin="0,0,8,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
          <StackPanel Margin="14,12">
            <TextBlock Text="邮箱池" Foreground="{StaticResource TextSub}"/>
            <TextBlock Text="{Binding MailboxCountText}" FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="2" Margin="0,0,8,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
          <StackPanel Margin="14,12">
            <TextBlock Text="已注册" Foreground="{StaticResource TextSub}"/>
            <TextBlock Text="{Binding RegisteredCountText}" FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="3" Margin="0,0,8,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
          <StackPanel Margin="14,12">
            <TextBlock Text="支付完成" Foreground="{StaticResource TextSub}"/>
            <TextBlock Text="{Binding PaypalCountText}" FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
        <Border Grid.Column="4" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6">
          <StackPanel Margin="14,12">
            <TextBlock Text="异常/待处理" Foreground="{StaticResource TextSub}"/>
            <TextBlock Text="{Binding AttentionCountText}" FontSize="24" FontWeight="SemiBold"/>
          </StackPanel>
        </Border>
      </Grid>

      <Border Grid.Row="1" Margin="0,8,0,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1">
        <Grid Margin="8,7">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="128"/>
            <ColumnDefinition Width="90"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="96"/>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="64"/>
            <ColumnDefinition Width="72"/>
          </Grid.ColumnDefinitions>
          <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" ToolTip="搜索邮箱、session、token、备注"/>
          <ComboBox Grid.Column="1" Margin="6,0,0,0" SelectedItem="{Binding ScopeFilter}">
            <ComboBoxItem Content="全部"/>
            <ComboBoxItem Content="邮箱池"/>
            <ComboBoxItem Content="已注册"/>
            <ComboBoxItem Content="待处理"/>
          </ComboBox>
          <TextBox Grid.Column="2" Margin="6,0,0,0" Text="{Binding PageSizeText, UpdateSourceTrigger=PropertyChanged}" ToolTip="每页条数"/>
          <TextBlock Grid.Column="3" Margin="10,0,0,0" Text="{Binding PageStatusText}" VerticalAlignment="Center" Foreground="{StaticResource TextSub}"/>
          <Button Grid.Column="4" Content="首页" Click="FirstPage_Click"/>
          <Button Grid.Column="5" Content="上一页" Click="PrevPage_Click"/>
          <Button Grid.Column="6" Content="清空选择" Click="ClearSelection_Click"/>
          <Button Grid.Column="7" Content="下一页" Click="NextPage_Click"/>
          <Button Grid.Column="8" Content="末页" Click="LastPage_Click"/>
          <Button Grid.Column="9" Content="全选" Click="SelectAllFiltered_Click" ToolTip="选中当前筛选结果"/>
        </Grid>
      </Border>

      <Border Grid.Row="2" Margin="0,8,0,0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1">
        <DataGrid x:Name="AccountGrid" ItemsSource="{Binding PagedRows}" SelectedItem="{Binding SelectedRow}" AutoGenerateColumns="False"
                  CanUserAddRows="False" HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                  RowHeight="28" IsReadOnly="False" AlternatingRowBackground="{StaticResource GridAltBg}"
                  BorderThickness="0" SelectionMode="Extended" SelectionUnit="FullRow"
                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                  SelectionChanged="AccountGrid_SelectionChanged">
          <DataGrid.Columns>
            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="80" IsReadOnly="True"/>
            <DataGridCheckBoxColumn Header="选中" Binding="{Binding IsChecked}" Width="60"/>
            <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt}" Width="155" IsReadOnly="True"/>
            <DataGridTextColumn Header="更新时间" Binding="{Binding CompletedAt}" Width="155" IsReadOnly="True"/>
            <DataGridTextColumn Header="邮箱" Binding="{Binding Identifier}" Width="260" IsReadOnly="True"/>
            <DataGridTextColumn Header="类型" Binding="{Binding AccountType}" Width="120" IsReadOnly="True"/>
            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="130" IsReadOnly="True"/>
            <DataGridTextColumn Header="支付状态" Binding="{Binding PayPalStatus}" Width="120" IsReadOnly="True"/>
            <DataGridTextColumn Header="支付金额" Binding="{Binding PayPalAmount}" Width="95" IsReadOnly="True"/>
            <DataGridTextColumn Header="Refresh" Binding="{Binding RefreshTokenStatus}" Width="120" IsReadOnly="True"/>
            <DataGridTemplateColumn Header="详情" Width="70">
              <DataGridTemplateColumn.CellTemplate>
                <DataTemplate>
                  <Button Content="查看" Height="24" Padding="6,0" Click="AccountDetail_Click"/>
                </DataTemplate>
              </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Token" Binding="{Binding RefreshToken}" Width="190" IsReadOnly="True"/>
            <DataGridTextColumn Header="代理/耗时" Binding="{Binding Proxy}" Width="150" IsReadOnly="True"/>
            <DataGridTextColumn Header="备注" Binding="{Binding Notes}" Width="520" IsReadOnly="True"/>
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <GridSplitter Grid.Row="3" Height="6" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    Background="{StaticResource SplitterBg}" ShowsPreview="True"/>

      <Grid Grid.Row="4" Margin="0,6,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="36" MinHeight="28"/>
          <RowDefinition Height="5"/>
          <RowDefinition Height="220" MinHeight="160"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Line}" BorderThickness="1">
          <DataGrid ItemsSource="{Binding Tasks}" AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                    IsReadOnly="True" RowHeight="26" BorderThickness="0"
                    ScrollViewer.HorizontalScrollBarVisibility="Auto"
                    ScrollViewer.VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
              <DataGridTextColumn Header="批次" Binding="{Binding Name}" Width="160"/>
              <DataGridTextColumn Header="任务" Binding="{Binding Task}" Width="160"/>
              <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
              <DataGridTextColumn Header="参数" Binding="{Binding Info}" Width="520"/>
              <DataGridTextColumn Header="耗时(s)" Binding="{Binding Cost}" Width="80"/>
              <DataGridTextColumn Header="完成时间" Binding="{Binding DoneAt}" Width="150"/>
            </DataGrid.Columns>
          </DataGrid>
        </Border>
        <GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                      Background="{StaticResource SplitterBg}" ShowsPreview="True"/>
        <Border Grid.Row="2" Background="{StaticResource LogBg}" BorderBrush="{StaticResource LogBorder}" BorderThickness="1" MinHeight="160">
          <Grid>
            <Button Content="清空日志" Width="78" Height="26" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,6,20,0" Panel.ZIndex="1" Click="ClearLog_Click"/>
            <TextBox Text="{Binding LogText}" Background="{StaticResource LogBg}" Foreground="{StaticResource LogText}" BorderThickness="0"
                   FontFamily="Consolas" FontSize="12" IsReadOnly="True" AcceptsReturn="True"
                   VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                   TextWrapping="NoWrap"
                   VerticalAlignment="Stretch" HorizontalAlignment="Stretch" MinHeight="160" Padding="8,34,8,8">
            <TextBox.Resources>
              <Style TargetType="{x:Type ScrollBar}">
                <Setter Property="Width" Value="15"/>
                <Setter Property="MinWidth" Value="15"/>
                <Setter Property="Height" Value="15"/>
                <Setter Property="MinHeight" Value="15"/>
                <Setter Property="Background" Value="#111C31"/>
                <Setter Property="Template">
                  <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                      <Grid Background="{TemplateBinding Background}">
                        <Track x:Name="PART_Track" Orientation="{TemplateBinding Orientation}" IsDirectionReversed="True">
                          <Track.Thumb>
                            <Thumb Background="#6F86A8">
                              <Thumb.Template>
                                <ControlTemplate TargetType="{x:Type Thumb}">
                                  <Border Background="{TemplateBinding Background}" CornerRadius="7"/>
                                </ControlTemplate>
                              </Thumb.Template>
                            </Thumb>
                          </Track.Thumb>
                        </Track>
                      </Grid>
                      <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                          <Setter Property="Width" Value="Auto"/>
                          <Setter Property="MinWidth" Value="0"/>
                          <Setter Property="Height" Value="15"/>
                          <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False"/>
                        </Trigger>
                        <Trigger Property="Orientation" Value="Vertical">
                          <Setter Property="Width" Value="15"/>
                          <Setter Property="Height" Value="Auto"/>
                          <Setter Property="MinHeight" Value="0"/>
                        </Trigger>
                      </ControlTemplate.Triggers>
                    </ControlTemplate>
                  </Setter.Value>
                </Setter>
              </Style>
            </TextBox.Resources>
            </TextBox>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="5" Background="{StaticResource StatusBg}" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0">
        <TextBlock Margin="8,3" Text="{Binding StatusText}" Foreground="{StaticResource TextSub}"/>
      </Border>
    </Grid>
  </Grid>
</Window>
